#!/usr/bin/env bash
set -euo pipefail

source_path="${BASH_SOURCE[0]}"
while [[ -L "${source_path}" ]]; do
  link_target="$(readlink "${source_path}")"
  if [[ "${link_target}" == /* ]]; then
    source_path="${link_target}"
  else
    source_dir="$(cd -- "$(dirname -- "${source_path}")" >/dev/null 2>&1 && pwd)"
    source_path="${source_dir}/${link_target}"
  fi
done

script_dir="$(cd -- "$(dirname -- "${source_path}")" >/dev/null 2>&1 && pwd)"
repo_root="$(cd -- "${script_dir}/.." >/dev/null 2>&1 && pwd)"
binary_path="${repo_root}/target/debug/convex-sync"

if [[ ! -f "${repo_root}/Cargo.toml" || ! -f "${repo_root}/apps/convex-sync/src/main.rs" ]]; then
  printf 'convex-sync-dev must run from a convex-streaming-olap-export checkout\n' >&2
  exit 1
fi

if ! command -v cargo >/dev/null 2>&1; then
  printf 'cargo is required for convex-sync-dev\n' >&2
  exit 1
fi

if command -v git >/dev/null 2>&1; then
  commit_sha="$(git -C "${repo_root}" rev-parse --short HEAD 2>/dev/null || printf 'unknown')"
  version_label="dev-${commit_sha}"
  if ! git -C "${repo_root}" diff --quiet HEAD 2>/dev/null; then
    version_label="${version_label}-dirty"
  fi
else
  version_label="dev-unknown"
fi

(
  cd "${repo_root}"
  CONVEX_SYNC_VERSION="${version_label}" cargo build -p convex-sync --quiet
)

reported_version="$("${binary_path}" --version 2>/dev/null | awk '{print $2}')"
if [[ "${reported_version}" != "${version_label}" ]]; then
  printf 'convex-sync-dev built %s but binary reported %s\n' "${version_label}" "${reported_version:-unknown}" >&2
  exit 1
fi

exec "${binary_path}" "$@"
