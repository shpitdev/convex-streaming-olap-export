          },
          {
            "name": "Silver Table",
            "expr": "silver_table",
            "displayName": "Silver Table"
          },
          {
            "name": "Silver Rows",
            "expr": "silver_row_count",
            "displayName": "Silver Rows"
          }
        ],
        "version": 1.1,
        "comment": "One row per logical table with bronze and silver record counts side by side."
      }
    }
