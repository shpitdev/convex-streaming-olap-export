{
  "datasets": [
    {
      "name": "sync_summary",
      "displayName": "Sync Summary",
      "config": {
        "source": "WITH checkpoint_latest AS ( SELECT source_id, phase, updated_at FROM `{{CATALOG}}`.`{{CONTROL_SCHEMA}}`.connector_checkpoint_latest ), checkpoint_counts AS ( SELECT source_id, COUNT(*) AS checkpoint_write_count FROM `{{CATALOG}}`.`{{CONTROL_SCHEMA}}`.`{{CHECKPOINT_TABLE}}` GROUP BY source_id ), bronze_tables AS ( SELECT COUNT(DISTINCT table_name) AS bronze_table_count FROM `{{CATALOG}}`.information_schema.tables WHERE table_schema = '{{BRONZE_SCHEMA}}' AND LEFT(table_name, 2) <> '__' AND table_name NOT LIKE 'event_log_%' AND table_type <> 'VIEW' ), silver_tables AS ( SELECT COUNT(DISTINCT table_name) AS silver_table_count FROM `{{CATALOG}}`.information_schema.tables WHERE table_schema = '{{SILVER_SCHEMA}}' AND LEFT(table_name, 2) <> '__' AND table_name NOT LIKE 'event_log_%' AND table_type <> 'VIEW' ) SELECT l.source_id, l.phase, l.updated_at, ROUND((UNIX_TIMESTAMP(CURRENT_TIMESTAMP()) - UNIX_TIMESTAMP(l.updated_at)) / 60.0, 2) AS checkpoint_lag_minutes, COALESCE(c.checkpoint_write_count, 0) AS checkpoint_write_count, b.bronze_table_count, s.silver_table_count FROM checkpoint_latest l LEFT JOIN checkpoint_counts c ON c.source_id = l.source_id CROSS JOIN bronze_tables b CROSS JOIN silver_tables s",
        "measures": [
          {
            "name": "Bronze Tables",
            "expr": "MAX(bronze_table_count)",
            "displayName": "Bronze Tables",
            "format": {
              "type": "number",
              "decimalPlaces": {
                "type": "exact",
                "places": 0
              }
            }
          },
          {
            "name": "Silver Tables",
            "expr": "MAX(silver_table_count)",
            "displayName": "Silver Tables",
            "format": {
              "type": "number",
              "decimalPlaces": {
                "type": "exact",
                "places": 0
              }
            }
          },
          {
            "name": "Checkpoint Lag Minutes",
            "expr": "MAX(checkpoint_lag_minutes)",
            "displayName": "Checkpoint Lag Minutes",
            "format": {
              "type": "number",
              "decimalPlaces": {
                "type": "exact",
                "places": 2
              }
            }
          },
          {
            "name": "Checkpoint Writes",
            "expr": "MAX(checkpoint_write_count)",
            "displayName": "Checkpoint Writes",
            "format": {
              "type": "number",
              "decimalPlaces": {
                "type": "exact",
                "places": 0
              }
            }
          }
        ],
        "dimensions": [
          {
            "name": "Source ID",
            "expr": "source_id",
            "displayName": "Source ID"
          },
          {
            "name": "Phase",
            "expr": "phase",
            "displayName": "Phase"
          },
          {
            "name": "Updated At",
            "expr": "updated_at",
            "displayName": "Updated At"
          },
          {
            "name": "Lag (min)",
            "expr": "checkpoint_lag_minutes",
            "displayName": "Lag (min)"
          }
        ],
        "version": 1.1,
        "comment": "High-level sync summary for {{SOURCE_LABEL}}."
      }
    },
    {
      "name": "recent_checkpoints",
      "displayName": "Recent Checkpoints",
      "config": {
        "source": "SELECT source_id, phase, snapshot_ts, delta_cursor, run_id, updated_at FROM `{{CATALOG}}`.`{{CONTROL_SCHEMA}}`.`{{CHECKPOINT_TABLE}}` ORDER BY updated_at DESC LIMIT 50",
        "dimensions": [
          {
            "name": "Source ID",
            "expr": "source_id",
            "displayName": "Source ID"
          },
          {
            "name": "Phase",
            "expr": "phase",
            "displayName": "Phase"
          },
          {
            "name": "Snapshot TS",
            "expr": "snapshot_ts",
            "displayName": "Snapshot TS"
          },
          {
            "name": "Delta Cursor",
            "expr": "delta_cursor",
            "displayName": "Delta Cursor"
          },
          {
            "name": "Run ID",
            "expr": "run_id",
            "displayName": "Run ID"
          },
          {
            "name": "Updated At",
            "expr": "updated_at",
            "displayName": "Updated At"
          }
        ],
        "version": 1.1,
        "comment": "Recent checkpoint writes."
      }
    },
    {
      "name": "delta_table_inventory",
      "displayName": "Delta Table Inventory",
      "config": {
        "source": "WITH bronze AS ( SELECT REGEXP_REPLACE(table_name, '__cdc$', '') AS logical_table, table_name AS bronze_table, CONCAT_WS(', ', SORT_ARRAY(COLLECT_SET(table_type))) AS bronze_type, MIN(created) AS bronze_created, MAX(last_altered) AS bronze_last_altered FROM `{{CATALOG}}`.information_schema.tables WHERE table_schema = '{{BRONZE_SCHEMA}}' AND LEFT(table_name, 2) <> '__' AND table_name NOT LIKE 'event_log_%' AND table_type <> 'VIEW' GROUP BY REGEXP_REPLACE(table_name, '__cdc$', ''), table_name ), silver AS ( SELECT table_name AS logical_table, table_name AS silver_table, CONCAT_WS(', ', SORT_ARRAY(COLLECT_SET(table_type))) AS silver_type, MIN(created) AS silver_created, MAX(last_altered) AS silver_last_altered FROM `{{CATALOG}}`.information_schema.tables WHERE table_schema = '{{SILVER_SCHEMA}}' AND LEFT(table_name, 2) <> '__' AND table_name NOT LIKE 'event_log_%' AND table_type <> 'VIEW' GROUP BY table_name ) SELECT COALESCE(b.logical_table, s.logical_table) AS logical_table, b.bronze_table, s.silver_table, b.bronze_type, s.silver_type, b.bronze_last_altered, s.silver_last_altered FROM bronze b FULL OUTER JOIN silver s ON b.logical_table = s.logical_table ORDER BY logical_table",
        "dimensions": [
          {
            "name": "Logical Table",
            "expr": "logical_table",
            "displayName": "Logical Table"
          },
          {
            "name": "Bronze Table",
            "expr": "bronze_table",
            "displayName": "Bronze Table"
          },
          {
            "name": "Silver Table",
            "expr": "silver_table",
            "displayName": "Silver Table"
          },
          {
            "name": "Bronze Type",
            "expr": "bronze_type",
            "displayName": "Bronze Type"
          },
          {
            "name": "Silver Type",
            "expr": "silver_type",
            "displayName": "Silver Type"
          },
          {
            "name": "Bronze Updated",
            "expr": "bronze_last_altered",
            "displayName": "Bronze Updated"
          },
          {
            "name": "Silver Updated",
            "expr": "silver_last_altered",
            "displayName": "Silver Updated"
          }
        ],
        "version": 1.1,
        "comment": "One row per logical table with bronze and silver side by side."
      }
    },
    {
      "name": "table_row_counts",
      "displayName": "Table Row Counts",
      "config": {
        "source": "{{TABLE_ROW_COUNTS_SOURCE}}",
        "dimensions": [
          {
            "name": "Logical Table",
            "expr": "logical_table",
            "displayName": "Logical Table"
          },
          {
            "name": "Bronze Table",
